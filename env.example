# Copy to .env.local and fill in. On Vercel, add the same keys in Project Settings → Environment Variables.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Must match your Supabase login email (owner only). Used by /admin middleware and /api/admin/data.
ADMIN_EMAIL=

# Same email as ADMIN_EMAIL — shows the "Admin" link in the nav (safe to expose; real lock is middleware).
NEXT_PUBLIC_ADMIN_EMAIL=

# Optional — shown on /contact (defaults to support@agenthub.com if unset).
NEXT_PUBLIC_CONTACT_EMAIL=

# Optional — used for message email notifications (if set, notifications send via Resend).
RESEND_API_KEY=
MESSAGE_FROM_EMAIL=
# Optional app URL used in email links (defaults to production domain in code).
NEXT_PUBLIC_APP_URL=
